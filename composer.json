{
    "name": "kaz29/phork",
    "description": "Runtime-based parallel test distribution tool for PHPUnit",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "brianium/paratest": "^7.0",
        "symfony/console": "^7.3.4",
        "symfony/process": "^7.3.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Phork\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phork\\Tests\\": "tests/"
        }
    },
    "bin": ["bin/phork"]
}
